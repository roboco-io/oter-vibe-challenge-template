#!/usr/bin/env bash
# Retrobot pre-push 훅
#
# push 시점에 retros/ 안의 최신 회고가 24시간을 넘겼거나 아예 없으면
# KPT 회고를 자동 생성하고 커밋한다.
#
# 안전 원칙:
#   - claude(및 폴백) CLI가 없거나 회고 생성이 실패해도 push는 절대 막지 않는다
#     (경고만 출력하고 exit 0).
#   - 방금 만든 커밋이 이미 Retrobot 회고 커밋이면 재귀적으로 다시 트리거하지 않는다.
set -uo pipefail

repo_root="$(git rev-parse --show-toplevel 2>/dev/null)" || exit 0
cd "$repo_root" || exit 0

retro_dir="retros"
skill_file="retrobot/SKILL.md"

warn() { echo "[retrobot] $*" >&2; }

# 1) 재귀 방지: 방금 만든 커밋이 Retrobot 회고 커밋이면 이번 트리거는 건너뛴다.
last_subject="$(git log -1 --pretty=%s 2>/dev/null || true)"
if [[ "$last_subject" == *"[Retrobot]"* ]]; then
  warn "최근 커밋이 Retrobot 회고 커밋입니다. 이번 push에서는 새 회고 생성을 건너뜁니다."
  exit 0
fi

mkdir -p "$retro_dir"

# 2) 최신 회고 파일 찾기 (파일명 YYYY-MM-DD-HHMM.md 기준 사전식 정렬 = 시간순 정렬)
latest_retro="$(find "$retro_dir" -maxdepth 1 -type f -name '20*-*-*-*.md' 2>/dev/null | sort | tail -n1)"

need_retro=1
if [[ -n "$latest_retro" && -f "$latest_retro" ]]; then
  base="$(basename "$latest_retro" .md)"       # e.g. 2026-07-04-0930
  datepart="${base:0:10}"                      # 2026-07-04
  timepart="${base:11:4}"                      # 0930
  file_epoch=""
  if [[ "$datepart" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}$ && "$timepart" =~ ^[0-9]{4}$ ]]; then
    hh="${timepart:0:2}"
    mm="${timepart:2:2}"
    # 파일명에 박힌 날짜를 우선 신뢰한다 (git checkout은 mtime을 보존하지 않으므로).
    file_epoch="$(date -j -f "%Y-%m-%d %H:%M" "$datepart $hh:$mm" +%s 2>/dev/null || true)"
    if [[ -z "$file_epoch" ]]; then
      file_epoch="$(date -d "$datepart $hh:$mm" +%s 2>/dev/null || true)"
    fi
  fi
  if [[ -z "$file_epoch" ]]; then
    # 파일명 파싱 실패 시 mtime으로 폴백 (macOS/Linux 모두 지원)
    file_epoch="$(stat -f %m "$latest_retro" 2>/dev/null || stat -c %Y "$latest_retro" 2>/dev/null || echo 0)"
  fi
  now_epoch="$(date +%s)"
  age=$(( now_epoch - file_epoch ))
  if (( age < 86400 )); then
    need_retro=0
  fi
fi

if (( need_retro == 0 )); then
  exit 0
fi

if [[ ! -f "$skill_file" ]]; then
  warn "retrobot/SKILL.md 를 찾을 수 없습니다. 회고 생성을 건너뜁니다."
  exit 0
fi

runner=""
if command -v claude >/dev/null 2>&1; then
  runner="claude"
elif command -v codex >/dev/null 2>&1; then
  runner="codex"
elif command -v gemini >/dev/null 2>&1; then
  runner="gemini"
else
  warn "claude/codex/gemini CLI를 찾을 수 없습니다. 회고 없이 push를 계속 진행합니다."
  warn "AI 도구 설치 후 다음 push부터 자동으로 회고가 생성됩니다."
  exit 0
fi

prompt="$(cat "$skill_file")"
err_log="$(mktemp)"
retro_content=""
case "$runner" in
  claude)
    retro_content="$(claude -p "$prompt" --dangerously-skip-permissions 2>"$err_log")"
    ;;
  codex)
    retro_content="$(codex exec "$prompt" 2>"$err_log")"
    ;;
  gemini)
    retro_content="$(gemini -p "$prompt" 2>"$err_log")"
    ;;
esac
status=$?

if (( status != 0 )) || [[ -z "$retro_content" ]]; then
  warn "회고 생성에 실패했습니다 (실행기: $runner, exit=$status). push는 계속 진행합니다."
  if [[ -s "$err_log" ]]; then
    warn "오류 로그(마지막 5줄): $(tail -n 5 "$err_log")"
  fi
  rm -f "$err_log"
  exit 0
fi
rm -f "$err_log"

retro_file="$retro_dir/$(date +%Y-%m-%d-%H%M).md"
printf '%s\n' "$retro_content" > "$retro_file"

git add "$retro_file"
if git commit -m "chore(retrobot): $(date +%Y-%m-%d) KPT 회고 [Retrobot]" --no-verify >/dev/null 2>&1; then
  warn "회고를 생성하고 커밋했습니다: $retro_file (이번이 아닌 다음 push부터 원격에 반영됩니다)"
else
  warn "회고 파일은 생성했지만 커밋에는 실패했습니다. 수동으로 커밋해주세요: $retro_file"
fi

exit 0
